@model IEnumerable<laba1.Models.Workout>
@{
	ViewData["Title"] = "Управление тренировками";
}
<h1>Управление тренировками</h1>
@if (TempData["SuccessMessage"] != null)
{
	<div class="alert alert-success alert-dismissible fade show" role="alert">
		@TempData["SuccessMessage"]
		<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
	</div>
}
<p>
	<a asp-action="Create" class="btn btn-primary">Добавить тренировку</a>
</p>
<table class="table table-striped table-hover">
	<thead>
		<tr>
			<th>ID</th>
			<th>Название</th>
			<th>Тип</th>
			<th>Длительность</th>
			<th>Калории</th>
			<th>Сложность</th>
			<th>Дата</th>
			<th>Действия</th>
		</tr>
	</thead>
	<tbody>
		@foreach (var item in Model)
		{
			<tr>
				<td>@item.Id</td>
				<td>@item.Name</td>
				<td>@item.Type</td>
				<td>@item.Duration мин</td>
				<td>@item.Calories</td>
				<td>@item.Difficulty</td>
				<td>@item.Date.ToString("dd.MM.yyyy")</td>
				<td>
					<a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Детали</a>
					<a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Изменить</a>
					<a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">Удалить</a>
				</td>
			</tr>
		}
	</tbody>
</table>
